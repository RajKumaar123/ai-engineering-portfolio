```gitignore
# --------------------------------------------------
# Python
# --------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# Compiled Extensions
*.so
*.pyd
*.dll

# Distribution / Packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual Environments
venv/
env/
ENV/
.venv/

# Environment Variables
.env
.env.*

# --------------------------------------------------
# Jupyter Notebook
# --------------------------------------------------
.ipynb_checkpoints/

# --------------------------------------------------
# VS Code
# --------------------------------------------------
.vscode/

# --------------------------------------------------
# PyCharm
# --------------------------------------------------
.idea/

# --------------------------------------------------
# Operating System
# --------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# --------------------------------------------------
# Logs
# --------------------------------------------------
*.log

# --------------------------------------------------
# Coverage
# --------------------------------------------------
.coverage
htmlcov/
.pytest_cache/

# --------------------------------------------------
# mypy
# --------------------------------------------------
.mypy_cache/

# --------------------------------------------------
# Ruff
# --------------------------------------------------
.ruff_cache/

# --------------------------------------------------
# Pyre
# --------------------------------------------------
.pyre/

# --------------------------------------------------
# Temporary Files
# --------------------------------------------------
*.tmp
*.temp

# --------------------------------------------------
# Model Checkpoints
# --------------------------------------------------
*.ckpt
*.h5
*.pth
*.pt

# --------------------------------------------------
# Vector Databases
# --------------------------------------------------
chroma/
chromadb/
faiss_index/

# --------------------------------------------------
# Local Databases
# --------------------------------------------------
*.db
*.sqlite
*.sqlite3

# --------------------------------------------------
# Secrets
# --------------------------------------------------
*.pem
*.key
credentials.json
service_account.json

# --------------------------------------------------
# Node (if used)
# --------------------------------------------------
node_modules/

# --------------------------------------------------
# Terraform
# --------------------------------------------------
.terraform/

# --------------------------------------------------
# Mac
# --------------------------------------------------
.AppleDouble
.LSOverride

# --------------------------------------------------
# Windows
# --------------------------------------------------
$RECYCLE.BIN/

# --------------------------------------------------
# Generated Media
# --------------------------------------------------
*.mp4
*.avi
*.mov
*.wav

# --------------------------------------------------
# Large AI Models (Keep Download Links Instead)
# --------------------------------------------------
*.bin
*.gguf
*.safetensors

# --------------------------------------------------
# Temporary Outputs
# --------------------------------------------------
outputs/
temp/
cache/
```
